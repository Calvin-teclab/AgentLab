# === 环境变量配置(教学注释) ===
# 把本文件复制为 .env 后填入真实值。
# .env 文件已经在 .gitignore 里,不会被提交到 GitHub。
#
# 至少配置其中一组(ARK_* 或 GEMINI_*)即可启动。
# 都配则前端可在"⚙ 后端配置"里切换 provider。

# ---------- 方舟 (DeepSeek 等) ----------
# 在 https://console.volcengine.com/ark 创建
ARK_API_KEY=your_api_key_here

# 推理接入点 ID,格式 ep-xxxxx(推荐,避免"模型未开通"的 404 错误)
# 在"在线推理 -> 自定义推理接入点"创建
ARK_MODEL=ep-xxxxxxxxx-xxxxx

# 方舟 OpenAI 兼容协议端点
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ---------- Google Gemini ----------
# 在 https://aistudio.google.com/apikey 创建 API Key
# 这里走 Gemini 的 OpenAI 兼容端点,不需要额外 SDK,跟方舟同一套调用
GEMINI_API_KEY=your_gemini_api_key_here

# 模型 ID,例如 gemini-flash-latest / gemini-2.5-flash / gemini-2.5-pro
GEMINI_MODEL=gemini-flash-latest

# Gemini OpenAI 兼容端点(一般不需要改)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
