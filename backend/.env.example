# === 环境变量配置(教学注释) ===
# 把本文件复制为 .env 后填入真实值。
# .env 文件已经在 .gitignore 里,不会被提交到 GitHub。

# 火山方舟 API Key,在 https://console.volcengine.com/ark 创建
ARK_API_KEY=your_api_key_here

# 推理接入点 ID,格式 ep-xxxxx(推荐,避免"模型未开通"的 404 错误)
# 在"在线推理 -> 自定义推理接入点"创建
ARK_MODEL=ep-xxxxxxxxx-xxxxx

# 后端端点(方舟 OpenAI 兼容协议)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
